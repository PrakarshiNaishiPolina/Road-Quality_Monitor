<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#F8FAFC"
    android:orientation="vertical"
    android:padding="20dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Title -->

    <TextView
        android:text="Admin Dashboard"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#1E3A8A"
        android:layout_marginBottom="20dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- Delete User Section -->

    <TextView
        android:text="Delete User Account"
        android:textStyle="bold"
        android:textColor="#111827"
        android:layout_marginBottom="5dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <EditText
        android:id="@+id/deleteUserInput"
        android:hint="Enter Employee ID"
        android:textColor="#111827"
        android:textColorHint="#6B7280"
        android:padding="12dp"
        android:background="@android:drawable/edit_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/deleteUserBtn"
        android:text="Delete User Account"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#DC2626"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- Scrollable Table -->

    <ScrollView
        android:layout_weight="1"
        android:layout_width="match_parent"
        android:layout_height="0dp">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TableLayout
                android:id="@+id/tableLayout"
                android:shrinkColumns="*"
                android:stretchColumns="1"
                android:padding="8dp"
                android:background="#FFFFFF"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </HorizontalScrollView>

    </ScrollView>


    <Button
        android:id="@+id/refreshBtn"
        android:text="Refresh Data"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2563EB"
        android:layout_marginTop="15dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/deleteBtn"
        android:text="Delete All Data"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#B91C1C"
        android:layout_marginTop="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/logoutBtn"
        android:text="Logout"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#374151"
        android:layout_marginTop="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- Logo -->

    <ImageView
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/srm_logo"
        android:layout_gravity="center"
        android:layout_marginTop="15dp"
        android:contentDescription="SRM Logo"/>

</LinearLayout>